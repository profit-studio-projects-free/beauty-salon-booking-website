# ----------------------------------------------------------------------
# Maison Lumière — Single Page App (Vite + React Router) on Apache/Hostinger
# Makes every route fall back to index.html so deep links and refreshes
# (e.g. /admin, /admin/appointments) load the app instead of a 404 / blank page.
# ----------------------------------------------------------------------

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Serve the app from the document root.
  RewriteBase /

  # If the request is for an existing file or directory, serve it as-is
  # (this covers /assets/*.js, /assets/*.css, /favicon.svg, etc.).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, send everything to index.html and let React Router handle it.
  RewriteRule ^ index.html [L]
</IfModule>

# ----------------------------------------------------------------------
# Correct MIME types so the browser actually executes the JS module.
# A wrong/empty MIME type is a common cause of a blank page on shared hosting.
# ----------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType text/javascript           .js .mjs
  AddType text/css                  .css
  AddType image/svg+xml             .svg
  AddType application/json          .json
  AddType application/font-woff     .woff
  AddType application/font-woff2    .woff2
</IfModule>

# ----------------------------------------------------------------------
# Caching: never cache index.html (so new deploys are picked up),
# cache fingerprinted assets aggressively.
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(?:html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(?:js|mjs|css|svg|woff|woff2|png|jpg|jpeg|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Optional: gzip compression for faster loads.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Don't expose directory listings.
Options -Indexes
